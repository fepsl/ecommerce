# =========================================================
# Copie este arquivo para .env e preencha com seus valores
# NUNCA commite o .env real no git
# =========================================================

# Banco de dados (usado pelo Spring Boot)
DB_URL=jdbc:postgresql://postgres:5432/ecommerce
DB_USER=ecommerce
DB_PASSWORD=ecommerce123

# PostgreSQL (usado pelo container Docker)
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce123

# JWT — MUDE ESTE VALOR EM PRODUÇÃO
# Deve ter pelo menos 32 caracteres (256 bits para HS256)
JWT_SECRET=mude-esta-chave-secreta-em-producao-minimo-32-chars

# Spring profile ativo (dev ou prod)
SPRING_PROFILES_ACTIVE=dev
